# ============================================================================
# SUPABASE Configuration (Required for all environments)
# ============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================================================
# ORDA API Configuration (Optional - for ORDA Registry integration)
# ============================================================================
ORDA_API_URL=https://api.orda-registry.org
ORDA_API_KEY=your-api-key-here
ORDA_ENVIRONMENT=production
ORDA_VERIFY_URL=https://verify.orda-registry.org

# ============================================================================
# Internal API Configuration (Required for /api/testament/log)
# ============================================================================
ORDA_INTERNAL_API_KEY=your-internal-api-key-here

# ============================================================================
# SAID-AIoT Configuration (For testing and development)
# ============================================================================
SAID_AIOT_ENVIRONMENT=production
SAID_AIOT_REGISTRY_URL=https://registry.said.dev

# ============================================================================
# GitHub Integration (Optional - for GitHub Actions)
# ============================================================================
GITHUB_TOKEN=your-github-token-here
GITHUB_REPOSITORY=courtneybtaylor-sys/ORDA-REGISTRY

# ============================================================================
# Vercel Integration (Optional - for Vercel deployment)
# ============================================================================
VERCEL_TOKEN=your-vercel-token-here
VERCEL_ORG_ID=your-org-id-here
VERCEL_PROJECT_ID=your-project-id-here
