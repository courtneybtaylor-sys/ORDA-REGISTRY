# ORDA API Configuration (Production)
# Get these credentials from the ORDA team

# ORDA API Endpoint
ORDA_API_URL=https://api.orda-registry.org

# ORDA API Key (required for all requests)
ORDA_API_KEY=your-api-key-here

# Public verification URL
ORDA_VERIFY_URL=https://verify.orda-registry.org

# Environment (production or sandbox)
ORDA_ENVIRONMENT=production
